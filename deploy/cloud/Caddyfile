# Caddy config for the autosapien cloud stack.
#
# Odoo's frontend uses absolute /web/... paths in its HTML, so we serve
# Odoo at the site ROOT (not under /odoo/*). Health endpoints get dedicated
# prefixes.
#
# Set DOMAIN + ADMIN_EMAIL in .env.cloud before launching.

{
    email {$ADMIN_EMAIL}
    admin off
}

{$DOMAIN} {
    encode gzip

    # Healthcheck + metrics — short, non-colliding prefixes.
    @health path /healthz /livez /metrics
    handle @health {
        reverse_proxy healthcheck:8080
    }

    # Odoo longpolling (the /websocket path) needs the 8072 service.
    handle /websocket* {
        reverse_proxy odoo:8072
    }

    # Everything else is Odoo. Absolute /web/..., /odoo/..., etc. all flow here.
    handle {
        reverse_proxy odoo:8069 {
            header_up X-Forwarded-Proto https
            header_up X-Real-IP {remote}
        }
    }

    log {
        output file /data/access.log {
            roll_size 100mb
            roll_keep 5
        }
    }
}
