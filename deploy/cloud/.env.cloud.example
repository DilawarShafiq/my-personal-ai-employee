# ============================================================================
# autosapien CLOUD env template (Platinum tier)
#
# Copy to .env.cloud on the cloud VM and fill in real values.
# NEVER commit .env.cloud. It is in .gitignore.
#
# Per hackathon spec § Platinum > Security rule, this file intentionally
# omits WhatsApp, banking, and payment creds. The cloud agent fails CLOSED
# if any of those variables are set.
# ============================================================================

# Role: must be "cloud". The orchestrator fails closed if mis-set.
AUTOSAPIEN_ROLE=cloud

# DRY_RUN stays true on Cloud. LIVE_CHANNELS is never set on Cloud — the
# human on Local is the only one who can flip a channel live.
DRY_RUN=true

# Vault path inside the container.
VAULT_PATH=/vault

# Domain served by Caddy (must have an A record pointing at this VM).
DOMAIN=autosapien-cloud.yourdomain.example
ADMIN_EMAIL=dilawar.gopang@gmail.com

# Gmail (same OAuth client as Local; Cloud has its own token).
# Mount the token file via docker volume at /secrets/gmail_token.json.
GMAIL_CREDENTIALS_PATH=/secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=/secrets/gmail_token.json
GMAIL_QUERY=is:unread -category:promotions newer_than:7d
ENABLE_GMAIL_WATCHER=true

# WhatsApp — hard-off on Cloud. Set to anything other than "true" (or omit).
# The cloud agent will refuse to boot if this is "true".
ENABLE_WHATSAPP_WATCHER=false

# Odoo (runs in the same compose project).
ODOO_URL=http://odoo:8069
ODOO_DB=autosapien
ODOO_USER=admin
ODOO_DB_PASSWORD=                     # REQUIRED — generate with `openssl rand -hex 16`

# Vault sync (git-based).
VAULT_REPO_URL=git@github.com:DilawarShafiq/autosapien-vault.git
VAULT_BRANCH=main
GIT_USER_EMAIL=cloud-agent@autosapien.example
GIT_USER_NAME=autosapien-cloud-agent

# Backblaze B2 for Odoo backups (optional — leave blank to store locally only).
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=

# Hard rate limits (enforced in code).
MAX_EMAILS_PER_HOUR=0                 # Cloud NEVER sends email. Only drafts.
MAX_SOCIAL_POSTS_PER_DAY=0            # Cloud NEVER posts. Only drafts.
MAX_PAYMENTS_PER_DAY=0                # Cloud NEVER touches payments.
