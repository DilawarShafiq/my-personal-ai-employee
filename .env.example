# ============================================================================
# autosapien.com Personal AI Employee — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================================

# Global safety switch. When true, every action script logs intent and exits
# WITHOUT performing external actions. Flip to false only for signed-off demos.
DRY_RUN=true

# Vault
VAULT_PATH=./AI_Employee_Vault

# Logging
LOG_LEVEL=INFO

# ---- Gmail (Silver tier) ----
GMAIL_CREDENTIALS_PATH=./secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=./secrets/gmail_token.json
GMAIL_QUERY=is:unread -category:promotions -category:social newer_than:7d

# ---- Watcher toggles (opt-in, off by default so first boot is safe) ----
ENABLE_GMAIL_WATCHER=false
ENABLE_WHATSAPP_WATCHER=false
WHATSAPP_SESSION_PATH=./secrets/whatsapp_session

# ---- LinkedIn (Silver tier) ----
# Using Playwright session rather than API to avoid OAuth review overhead.
LINKEDIN_SESSION_PATH=./secrets/linkedin_session
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/autosapien/

# ---- Twitter / X (Gold tier) ----
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ---- Facebook + Instagram (Gold tier) ----
META_PAGE_ID=
META_IG_USER_ID=
META_LONG_LIVED_TOKEN=

# ---- Odoo (Gold tier) ----
ODOO_URL=http://localhost:8069
ODOO_DB=autosapien
ODOO_USER=admin
ODOO_PASSWORD=
ODOO_API_KEY=

# ---- Rate limits (hard caps enforced in code) ----
MAX_EMAILS_PER_HOUR=10
MAX_SOCIAL_POSTS_PER_DAY=6
MAX_PAYMENTS_PER_DAY=3
